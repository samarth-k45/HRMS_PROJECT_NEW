<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>HR Management System</display-name>

    <!-- Welcome / default page -->
    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

    <!-- ===================== SERVLET DECLARATIONS ===================== -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.hrms.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.hrms.servlet.DashboardServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>EmployeeServlet</servlet-name>
        <servlet-class>com.hrms.servlet.EmployeeServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>AttendanceServlet</servlet-name>
        <servlet-class>com.hrms.servlet.AttendanceServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>LeaveServlet</servlet-name>
        <servlet-class>com.hrms.servlet.LeaveServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>PayrollServlet</servlet-name>
        <servlet-class>com.hrms.servlet.PayrollServlet</servlet-class>
    </servlet>

    <!-- ===================== SERVLET MAPPINGS ===================== -->

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/login</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/api/dashboard</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>EmployeeServlet</servlet-name>
        <url-pattern>/api/employees</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AttendanceServlet</servlet-name>
        <url-pattern>/api/attendance</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LeaveServlet</servlet-name>
        <url-pattern>/api/leaves</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>PayrollServlet</servlet-name>
        <url-pattern>/api/payroll</url-pattern>
    </servlet-mapping>

    <!-- ===================== SESSION CONFIGURATION ===================== -->
    <session-config>
        <!-- Session expires after 30 minutes of inactivity -->
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
